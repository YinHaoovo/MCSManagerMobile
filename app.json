{
  "expo": {
    "name": "MCSManager Mobile",
    "slug": "mcsm-mobile",
    "version": "1.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "automatic",
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.mcsm.mobile"
    },
    "android": {
      "package": "com.mcsm.mobile"
    },
    "plugins": [
      "expo-router",
      "expo-secure-store"
    ],
    "scheme": "mcsm",
    "extra": {
      "router": {
        "origin": false
      },
      "eas": {
        "projectId": "4b4fc158-6aef-4075-ac14-71a49d280125"
      }
    },
    "owner": "yin_hao"
  }
}
